# Em produção com PM2 em cluster (`-i max`), cada worker abre seu próprio pool.
# Ajuste `connection_limit` para (max_connections_do_MySQL / nº_de_workers) para
# não estourar o limite de conexões do banco. Ex.: ...DBNAME?connection_limit=10
DATABASE_URL="mysql://USER:PASSWORD@ADRESS:PORT/DBNAME"
BASE_URL=""
PORT=
BASE_URL_FRONTEND=""
# Obrigatório, mínimo de 32 caracteres. Gere um valor aleatório forte, ex.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="YOURSECRET"
# Segredo exclusivo (mínimo 32 caracteres) dos access tokens de clientes da loja.
# Em produção é obrigatório e deve ser diferente de JWT_SECRET.
LOJA_CUSTOMER_JWT_SECRET="ANOTHER_LONG_RANDOM_SECRET"
# Origens adicionais, separadas por vírgula; BASE_URL_FRONTEND já é permitida.
LOJA_CORS_ALLOWLIST="http://localhost:5173"
NODE_ENV="development"
# Só pode ser "false" em desenvolvimento; em produção o boot falha se não for "true".
REQUIRED_JWT="true"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
REDIS_HOST=""
REDIS_PORT=45645
REDIS_PASSWORD=""
ASAAS_API_KEY=""
ASAAS_WEBHOOK_SECRET=""
MP_ACCESS_TOKEN=""
ABACATEPAY_API_KEY=""
ABACATEPAY_WEBHOOK_SECRET=""
WHATSAPP_WAPI_BASE_URL=""
WHATSAPP_WAPI_ACCOUNT_TOKEN=""
EMAIL_SENDER=""
EMAIL_PASSWORD=""
# Resend (e-mails transacionais). RESEND_FROM deve ser de um domínio verificado
# no Resend; sem domínio verificado, use "onboarding@resend.dev" (entrega só para
# o e-mail dono da conta). Deixe RESEND_API_KEY vazio para desativar o envio.
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"
GEMINI_API_KEY=""

# Storage público opcional (S3/R2 compatível)
# Se deixar vazio, o backend usa upload local em ./public/uploads
# R2_ENDPOINT = domínio/base pública de leitura dos arquivos
# Ex.: https://cdn.userp.com.br
R2_ENDPOINT=""
# R2_API_ENDPOINT = endpoint S3 compatível usado pelo SDK para upload/delete
# Ex.: https://<accountid>.r2.cloudflarestorage.com
R2_API_ENDPOINT=""
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
