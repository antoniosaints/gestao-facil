generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status {
  ATIVO
  INATIVO
  BLOQUEADO
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  Usuarios  Usuarios @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  endpoint  String   @db.Text
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StatusFatura {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

model FaturasContas {
  id             Int          @id @default(autoincrement())
  contaId        Int
  conta          Contas       @relation(fields: [contaId], references: [id])
  Uid            String       @default("INV_000")
  asaasPaymentId String       @unique
  descricao      String?
  vencimento     DateTime
  valor          Float
  urlPagamento   String
  status         StatusFatura @default(PENDENTE)
  criadoEm       DateTime     @default(now())
}

enum GatewayConta {
  mercadopago
  abacatepay
  asaass
}

enum LojaTemplate {
  ESSENCIAL
  EDITORIAL
  IMPACTO
}

enum LojaGateway {
  MERCADOPAGO
  ABACATEPAY
}

enum LojaCanalPedido {
  WHATSAPP
  GATEWAY
}

enum LojaTipoEntrega {
  RETIRADA
  ENTREGA_LOCAL
}

enum LojaPedidoStatus {
  RECEBIDO
  CONFIRMADO
  PREPARANDO
  DESPACHADO
  CONCLUIDO
  CANCELAMENTO_PENDENTE
  CANCELADO
  EXPIRADO
  REVISAO
}

enum LojaPagamentoStatus {
  NAO_APLICAVEL
  PENDENTE
  PAGO
  FALHOU
  ESTORNADO
  REVISAO
}

enum LojaReservaStatus {
  ATIVA
  CONFIRMADA
  CONSUMIDA
  LIBERADA
  EXPIRADA
}

enum LojaClienteStatus {
  PENDENTE_VERIFICACAO
  ATIVO
  BLOQUEADO
}

enum LojaClienteTokenTipo {
  VERIFICACAO_EMAIL
  REDEFINICAO_SENHA
}

enum LojaCheckoutStatus {
  PENDENTE
  PRONTO
  FALHOU
  EXPIRADO
}

model Contas {
  id                              Int                               @id @default(autoincrement())
  nome                            String
  valor                           Decimal                           @db.Decimal(10, 2)
  valorBasePlano                  Decimal                           @default(70) @db.Decimal(10, 2)
  data                            DateTime
  profile                         String?                           @default("imgs/logo.png")
  status                          Status                            @default(ATIVO)
  vencimento                      DateTime                          @default(now())
  tipo                            String?
  documento                       String?
  ie                              String?
  im                              String?
  regimeTributario                Int                               @default(0)
  regimeTributarioEspecial        Int                               @default(0)
  ambiente                        String                            @default("homologacao")
  certificadoPath                 String?
  chaveAcesso                     String?
  funcionarios                    Int                               @default(0)
  categoria                       String?
  gateway                         GatewayConta                      @default(mercadopago)
  email                           String
  telefone                        String?
  endereco                        String?
  nomeFantasia                    String?
  cep                             String?
  emailAvisos                     String?
  asaasCustomerId                 String
  asaasSubscriptionId             String?
  dicasNovidades                  Boolean?                          @default(false)
  codigoIndicacao                 String?                           @unique
  indicadoPorContaId              Int?
  indicadoPorConta                Contas?                           @relation("IndicacaoConta", fields: [indicadoPorContaId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  indicados                       Contas[]                          @relation("IndicacaoConta")
  indicacaoRecompensada           Boolean                           @default(false)
  creditoIndicacao                Decimal                           @default(0) @db.Decimal(10, 2)
  indicacoesFeitas                IndicacaoRecompensa[]             @relation("IndicadorRecompensa")
  indicacoesRecebidas             IndicacaoRecompensa[]             @relation("IndicadoRecompensa")
  createdAt                       DateTime                          @default(now())
  updatedAt                       DateTime                          @updatedAt
  Produto                         Produto[]
  ProdutoBase                     ProdutoBase[]
  ProdutoCategoria                ProdutoCategoria[]
  Clientes                        ClientesFornecedores[]
  Vendas                          Vendas[]
  MovimentacoesEstoque            MovimentacoesEstoque[]
  Usuarios                        Usuarios[]
  FaturasContas                   FaturasContas[]
  ContasFinanceiro                ContasFinanceiro[]
  CategoriaFinanceiro             CategoriaFinanceiro[]
  LancamentoFinanceiro            LancamentoFinanceiro[]
  Servicos                        Servicos[]
  OrdensServico                   OrdensServico[]
  ParametrosConta                 ParametrosConta[]
  CobrancasFinanceiras            CobrancasFinanceiras[]
  assinaturas                     Assinatura[]
  planosAssinatura                PlanoAssinatura[]
  assinaturasClientes             AssinaturaCliente[]
  assinaturasPagar                AssinaturaPagar[]
  notaFiscals                     NotaFiscal[]
  arenaQuadras                    ArenaQuadras[]
  comandaVendas                   ComandaVenda[]
  comandasOperacao                ComandaOperacao[]
  comandasOperacaoConfiguracao    ComandaOperacaoConfiguracao?
  moduloOnContas                  ModuloOnConta[]
  LojaVirtualConfig               LojaVirtualConfig?
  LojaClientes                    LojaCliente[]
  LojaPedidos                     LojaPedido[]
  LojaReservas                    LojaReservaEstoque[]
  LojaCheckoutTentativas          LojaCheckoutTentativa[]
  LojaWebhookEventos              LojaWebhookEvento[]
  LojaIdempotencias               LojaIdempotencia[]
  LojaSecoes                      LojaSecao[]
  WhatsAppInstancia               WhatsAppInstancia[]
  WhatsAppContato                 WhatsAppContato[]
  WhatsAppConversa                WhatsAppConversa[]
  WhatsAppConversaEvento          WhatsAppConversaEvento[]
  WhatsAppMensagem                WhatsAppMensagem[]
  WhatsAppWebhookEvento           WhatsAppWebhookEvento[]
  WhatsAppInstanciaPagamento      WhatsAppInstanciaPagamento[]
  WhatsAppAgente                  WhatsAppAgente[]
  NotificacaoVencimentoFinanceiro NotificacaoVencimentoFinanceiro[]
  metas                           Meta[]
  PdvPonto                        PdvPonto[]
  CaixaSessao                     CaixaSessao[]
}

model ModulosAdicionais {
  id             Int             @id @default(autoincrement())
  codigo         String          @unique
  nome           String
  descricao      String?
  categoria      String
  preco          Decimal         @db.Decimal(10, 2)
  status         Boolean         @default(true)
  desconto       Decimal?        @default(0) @db.Decimal(10, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  moduloOnContas ModuloOnConta[]
}

model ModuloOnConta {
  id                       Int                      @id @default(autoincrement())
  vencimento               DateTime                 @default(now())
  valorAdicional           Decimal                  @default(0) @db.Decimal(10, 2)
  status                   StatusModuloConta        @default(ATIVO)
  ativoDesde               DateTime                 @default(now())
  solicitadoCancelamentoEm DateTime?
  canceladoEm              DateTime?
  tipoCobrancaAtual        TipoCobrancaModuloConta?
  valorCobrancaAtual       Decimal?                 @db.Decimal(10, 2)
  cobrancaAtualId          Int?                     @unique
  CobrancaAtual            CobrancasFinanceiras?    @relation("ModuloCobrancaAtual", fields: [cobrancaAtualId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  moduloId                 Int
  Modulos                  ModulosAdicionais        @relation(fields: [moduloId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  contaId                  Int
  Contas                   Contas                   @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@unique([moduloId, contaId], map: "ModuloOnConta_moduloId_contaId_key")
}

// Configuração da Loja Virtual (módulo pago). Uma por conta. Guarda a customização visual da
// vitrine (cores, estilo de header, banner, textos) e toggles de comportamento. Os campos de
// login/cadastro de cliente são usados na Fase B (autenticação do cliente da loja).
model LojaVirtualConfig {
  id                        Int          @id @default(autoincrement())
  contaId                   Int          @unique
  Conta                     Contas       @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  slug                      String       @unique
  template                  LojaTemplate @default(ESSENCIAL)
  themeVersion              Int          @default(1)
  themeConfig               Json?
  corPrimaria               String       @default("#4f46e5")
  corSecundaria             String       @default("#0ea5e9")
  headerEstilo              String       @default("padrao")
  bannerUrl                 String?      @db.Text
  bannerMobileUrl           String?      @db.Text
  bannerTitulo              String?
  bannerSubtitulo           String?
  mensagemBoasVindas        String?      @db.Text
  mostrarPrecos             Boolean      @default(true)
  mostrarDisponibilidade    Boolean      @default(true)
  ocultarEsgotados          Boolean      @default(false)
  quickAdd                  Boolean      @default(true)
  pedidoWhatsapp            Boolean      @default(true)
  pagamentoOnline           Boolean      @default(false)
  gatewayPreferido          LojaGateway?
  permitirLogin             Boolean      @default(false)
  permitirCadastro          Boolean      @default(false)
  permitirCheckoutVisitante Boolean      @default(true)
  retiradaAtiva             Boolean      @default(true)
  entregaLocalAtiva         Boolean      @default(false)
  taxaEntrega               Decimal      @default(0) @db.Decimal(10, 2)
  freteGratisAcima          Decimal?     @db.Decimal(10, 2)
  barraAvisoAtiva           Boolean      @default(false)
  barraAvisoTexto           String?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
}

// Seção manual/customizada da loja: o lojista cria seções (ex.: "Coleção verão") e escolhe
// a dedo quais produtos base aparecem nela. As seções automáticas (Promoções/Mais vendidos/
// Novidades) são apenas flags no themeConfig, não moram aqui.
model LojaSecao {
  id        Int                @id @default(autoincrement())
  contaId   Int
  Conta     Contas             @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  nome      String
  ordem     Int                @default(0)
  ativo     Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  produtos  LojaSecaoProduto[]

  @@index([contaId])
}

model LojaSecaoProduto {
  id            Int         @id @default(autoincrement())
  contaId       Int
  secaoId       Int
  LojaSecao     LojaSecao   @relation(fields: [secaoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  produtoBaseId Int
  ProdutoBase   ProdutoBase @relation(fields: [produtoBaseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ordem         Int         @default(0)
  createdAt     DateTime    @default(now())

  @@unique([secaoId, produtoBaseId])
  @@index([contaId])
  @@index([produtoBaseId])
}

model LojaCliente {
  id                Int                   @id @default(autoincrement())
  contaId           Int
  Conta             Contas                @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clienteId         Int?
  Cliente           ClientesFornecedores? @relation(fields: [clienteId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  nome              String
  email             String
  emailNormalizado  String
  telefone          String?
  senhaHash         String
  status            LojaClienteStatus     @default(PENDENTE_VERIFICACAO)
  emailVerificadoEm DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  sessoes           LojaClienteSessao[]
  tokens            LojaClienteToken[]
  enderecos         LojaClienteEndereco[]
  pedidos           LojaPedido[]

  @@unique([contaId, emailNormalizado])
  @@unique([id, contaId])
  @@index([contaId, clienteId])
}

model LojaClienteSessao {
  id               Int         @id @default(autoincrement())
  contaId          Int
  lojaClienteId    Int
  Cliente          LojaCliente @relation(fields: [lojaClienteId, contaId], references: [id, contaId], onDelete: Cascade, onUpdate: Cascade)
  refreshTokenHash String      @unique
  userAgent        String?     @db.Text
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime    @default(now())

  @@index([contaId, lojaClienteId, expiresAt])
}

model LojaClienteToken {
  id            Int                  @id @default(autoincrement())
  contaId       Int
  lojaClienteId Int
  Cliente       LojaCliente          @relation(fields: [lojaClienteId, contaId], references: [id, contaId], onDelete: Cascade, onUpdate: Cascade)
  tipo          LojaClienteTokenTipo
  tokenHash     String               @unique
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime             @default(now())

  @@index([contaId, lojaClienteId, tipo, expiresAt])
}

model LojaClienteEndereco {
  id            Int         @id @default(autoincrement())
  contaId       Int
  lojaClienteId Int
  Cliente       LojaCliente @relation(fields: [lojaClienteId, contaId], references: [id, contaId], onDelete: Cascade, onUpdate: Cascade)
  rotulo        String?
  destinatario  String
  cep           String
  endereco      String
  numero        String
  complemento   String?
  bairro        String
  cidade        String
  estado        String
  principal     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([contaId, lojaClienteId, principal])
}

model LojaPedido {
  id                  Int                     @id @default(autoincrement())
  contaId             Int
  Conta               Contas                  @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  publicId            String                  @unique
  accessTokenHash     String
  Uid                 String
  clienteLojaId       Int?
  ClienteLoja         LojaCliente?            @relation(fields: [clienteLojaId, contaId], references: [id, contaId], onDelete: Restrict, onUpdate: Cascade)
  clienteId           Int?
  Cliente             ClientesFornecedores?   @relation(fields: [clienteId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  vendaId             Int?                    @unique
  Venda               Vendas?                 @relation(fields: [vendaId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status              LojaPedidoStatus        @default(RECEBIDO)
  pagamentoStatus     LojaPagamentoStatus     @default(NAO_APLICAVEL)
  canal               LojaCanalPedido
  gateway             LojaGateway?
  tipoEntrega         LojaTipoEntrega
  nomeSnapshot        String
  emailSnapshot       String?
  telefoneSnapshot    String
  cepSnapshot         String?
  enderecoSnapshot    String?
  numeroSnapshot      String?
  complementoSnapshot String?
  bairroSnapshot      String?
  cidadeSnapshot      String?
  estadoSnapshot      String?
  subtotal            Decimal                 @db.Decimal(10, 2)
  frete               Decimal                 @default(0) @db.Decimal(10, 2)
  total               Decimal                 @db.Decimal(10, 2)
  observacao          String?                 @db.Text
  reservaExpiraEm     DateTime?
  confirmadoEm        DateTime?
  pagoEm              DateTime?
  preparandoEm        DateTime?
  despachadoEm        DateTime?
  concluidoEm         DateTime?
  canceladoEm         DateTime?
  codigoRastreio      String?
  transportadora      String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  itens               LojaPedidoItem[]
  reservas            LojaReservaEstoque[]
  tentativasCheckout  LojaCheckoutTentativa[]
  cobrancas           CobrancasFinanceiras[]

  @@unique([contaId, Uid])
  @@unique([id, contaId])
  @@index([contaId, status, createdAt])
  @@index([contaId, pagamentoStatus, reservaExpiraEm])
}

model LojaPedidoItem {
  id                    Int                 @id @default(autoincrement())
  contaId               Int
  pedidoId              Int
  Pedido                LojaPedido          @relation(fields: [pedidoId, contaId], references: [id, contaId], onDelete: Cascade, onUpdate: Cascade)
  produtoId             Int
  Produto               Produto             @relation(fields: [produtoId, contaId], references: [id, contaId], onDelete: Restrict, onUpdate: Cascade)
  produtoNomeSnapshot   String
  varianteNomeSnapshot  String?
  skuSnapshot           String?
  imagemSnapshot        String?             @db.Text
  unidadeSnapshot       String?
  precoUnitarioSnapshot Decimal             @db.Decimal(10, 2)
  quantidade            Int
  subtotal              Decimal             @db.Decimal(10, 2)
  controlaEstoque       Boolean             @default(false)
  createdAt             DateTime            @default(now())
  reserva               LojaReservaEstoque?

  @@unique([id, contaId])
  @@index([contaId, pedidoId])
  @@index([contaId, produtoId])
}

model LojaReservaEstoque {
  id           Int                   @id @default(autoincrement())
  contaId      Int
  Conta        Contas                @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pedidoId     Int
  Pedido       LojaPedido            @relation(fields: [pedidoId, contaId], references: [id, contaId], onDelete: Cascade, onUpdate: Cascade)
  pedidoItemId Int                   @unique
  PedidoItem   LojaPedidoItem        @relation(fields: [pedidoItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  produtoId    Int
  Produto      Produto               @relation(fields: [produtoId, contaId], references: [id, contaId], onDelete: Restrict, onUpdate: Cascade)
  quantidade   Int
  status       LojaReservaStatus     @default(ATIVA)
  expiresAt    DateTime?
  consumedAt   DateTime?
  releasedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  movimentacao MovimentacoesEstoque?

  @@index([contaId, produtoId, status])
  @@index([contaId, status, expiresAt])
}

model LojaCheckoutTentativa {
  id                Int                @id @default(autoincrement())
  contaId           Int
  Conta             Contas             @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pedidoId          Int
  Pedido            LojaPedido         @relation(fields: [pedidoId, contaId], references: [id, contaId], onDelete: Cascade, onUpdate: Cascade)
  gateway           LojaGateway
  idempotencyKey    String
  status            LojaCheckoutStatus @default(PENDENTE)
  referenciaExterna String?
  checkoutUrl       String?            @db.Text
  erro              String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([contaId, idempotencyKey])
  @@index([contaId, pedidoId, status])
}

model LojaWebhookEvento {
  id          Int         @id @default(autoincrement())
  contaId     Int
  Conta       Contas      @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  provider    LojaGateway
  eventId     String
  payload     Json?
  processedAt DateTime?
  erro        String?     @db.Text
  createdAt   DateTime    @default(now())

  @@unique([contaId, provider, eventId])
  @@index([contaId, processedAt])
}

model LojaIdempotencia {
  id           Int      @id @default(autoincrement())
  contaId      Int
  Conta        Contas   @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  escopo       String
  chave        String
  requestHash  String
  recursoTipo  String?
  recursoId    String?
  responseCode Int?
  responseBody Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([contaId, escopo, chave])
  @@index([contaId, expiresAt])
}

enum StatusModuloConta {
  PENDENTE_ATIVACAO
  ATIVO
  CANCELAMENTO_AGENDADO
  CANCELADO
}

enum TipoCobrancaModuloConta {
  PROPORCIONAL
  MENSAL
}

model Meta {
  id             Int                       @id @default(autoincrement())
  contaId        Int
  Contas         Contas                    @relation(fields: [contaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  nome           String
  descricao      String?
  tipo           TipoMeta
  metrica        MetricaMeta               @default(VALOR)
  periodicidade  PeriodicidadeMeta         @default(MENSAL)
  valorAlvo      Decimal                   @db.Decimal(12, 2)
  dataInicio     DateTime
  dataFim        DateTime?
  financeiroTipo TipoLancamentoFinanceiro?
  ativo          Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([contaId, tipo, ativo])
  @@index([contaId, periodicidade, dataInicio])
}

enum TipoMeta {
  VENDAS
  SERVICOS
  FINANCEIRO
}

enum MetricaMeta {
  VALOR
  QUANTIDADE
}

enum PeriodicidadeMeta {
  MENSAL
  TRIMESTRAL
  ANUAL
  PERSONALIZADO
}

model ParametrosConta {
  id                                     Int      @id @default(autoincrement())
  contaId                                Int      @unique
  Contas                                 Contas   @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  MercadoPagoApiKey                      String?
  AbacatePayApiKey                       String?
  AbacatePaySecret                       String?
  gatewayRecebimentoSaas                 String?
  WhatsappAPIToken                       String?
  WhatsappAPISession                     String?
  WhatsappAPINumber                      String?
  AsaasApiKey                            String?
  AsaasApiSecret                         String?
  MercadoPagoEnv                         String?
  AsaasEnv                               String?
  emailAvisos                            String?
  eventoVendaConcluida                   Boolean? @default(true)
  eventoSangria                          Boolean? @default(false)
  eventoEstoqueBaixo                     Boolean? @default(true)
  eventoProdutoAlterado                  Boolean? @default(true)
  permitirLancamentoRetroativo           Boolean? @default(true)
  permitirEfetivacaoFutura               Boolean? @default(true)
  permitirTransferenciaContaFinanceira   Boolean? @default(true)
  permitirCriacaoCobranca                Boolean? @default(true)
  modeloPdv                              String?  @default("BASICO")
  temaPersonalizado                      Json?
  linkPublicoAtivo                       Boolean? @default(false)
  cadastrosPermitidosLinkPublico         Int?     @default(1)
  chavePix                               String?
  menusVisiveis                          Json?
  etiquetaModelos                        Json?
  // Override do limite mensal de tokens de IA desta conta (null = usa o padrão global do CEO).
  iaLimiteTokensMensal                   Int?
  whatsappNotificacoesAtivo              Boolean? @default(false)
  whatsappNotificacoesInstanciaId        Int?
  whatsappEventoNovaVenda                Boolean? @default(true)
  whatsappEventoNovaOs                   Boolean? @default(true)
  whatsappEventoNovoLancamento           Boolean? @default(true)
  whatsappEventoNovoCliente              Boolean? @default(true)
  whatsappEventoComandaFaturada          Boolean? @default(true)
  whatsappEventoCaixaAberto              Boolean? @default(true)
  whatsappEventoCaixaFechado             Boolean? @default(true)
  financeiroVencimentosNotificacoesAtivo Boolean? @default(true)
  corPrimaria                            String?
  corSecundaria                          String?
  indicacaoAtiva                         Boolean? @default(false)
  indicacaoTipoRecompensa                String?  @default("PERCENTUAL")
  indicacaoValorRecompensa               Decimal? @default(0) @db.Decimal(10, 2)
  indicacaoTipoBonusIndicado             String?  @default("PERCENTUAL")
  indicacaoValorBonusIndicado            Decimal? @default(0) @db.Decimal(10, 2)
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime @updatedAt
}

model IndicacaoRecompensa {
  id               Int      @id @default(autoincrement())
  indicadorContaId Int
  indicadorConta   Contas   @relation("IndicadorRecompensa", fields: [indicadorContaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  indicadoContaId  Int
  indicadoConta    Contas   @relation("IndicadoRecompensa", fields: [indicadoContaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tipo             String
  valor            Decimal  @db.Decimal(10, 2)
  faturaId         Int?
  createdAt        DateTime @default(now())

  @@index([indicadorContaId])
