}

model WhatsAppInstancia {
  id                     Int                          @id @default(autoincrement())
  contaId                Int
  Conta                  Contas                       @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  nome                   String
  instanceId             String                       @unique
  token                  String                       @db.Text
  webhookSecret          String                       @unique
  status                 WhatsAppInstanciaStatus      @default(PENDENTE)
  numeroConectado        String?
  devicePayload          String?                      @db.Text
  ultimoErro             String?                      @db.Text
  ativo                  Boolean                      @default(true)
  // Controle de atendimento sem desconectar a API: "não perturbe" para de salvar os eventos
  // de mensagem recebida; horaInicio/horaFim (fuso America/Sao_Paulo) definem a janela em que
  // os eventos são salvos — fora dela também paramos de salvar. Nulo = sem restrição de horário.
  atendimentoNaoPerturbe Boolean                      @default(false)
  atendimentoHoraInicio  String?
  atendimentoHoraFim     String?
  lastSyncAt             DateTime?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  conversas              WhatsAppConversa[]
  mensagens              WhatsAppMensagem[]
  webhookEventos         WhatsAppWebhookEvento[]
  pagamentos             WhatsAppInstanciaPagamento[]
  agentes                WhatsAppAgenteInstancia[]

  @@unique([contaId, instanceId])
  @@index([contaId, status])
}

model WhatsAppInstanciaPagamento {
  id                Int                     @id @default(autoincrement())
  contaId           Int
  Conta             Contas                  @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  instanciaId       Int
  Instancia         WhatsAppInstancia       @relation(fields: [instanciaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  metodo            WhatsAppPagamentoMetodo
  status            WhatsAppPagamentoStatus @default(PENDENTE)
  payerEmail        String
  webhookPaymentUrl String?                 @db.Text
  paymentId         String?
  sessionId         String?
  qrCodeBase64      String?                 @db.LongText
  qrCodeCopyPaste   String?                 @db.LongText
  ticketUrl         String?                 @db.Text
  checkoutUrl       String?                 @db.Text
  rawPayload        String?                 @db.LongText
  pagoEm            DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([contaId, instanciaId, status, createdAt], map: "wa_pagto_conta_inst_status_created_idx")
  @@index([paymentId], map: "wa_pagto_payment_id_idx")
  @@index([sessionId], map: "wa_pagto_session_id_idx")
}

// Agente de IA para autoatendimento: enquanto a conversa está em espera (PENDENTE) e sem
// atendente humano, o agente responde o cliente. Só atende as instâncias vinculadas
// (WhatsAppAgenteInstancia), dentro dos dias/horários configurados e se estiver ativo.
model WhatsAppAgente {
  id         Int                       @id @default(autoincrement())
  contaId    Int
  Conta      Contas                    @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  nome       String
  prompt     String                    @db.Text
  modelo     String                    @default("gemini-2.0-flash")
  ativo      Boolean                   @default(true)
  // Janela de atendimento (horário local America/Sao_Paulo). Nulo = sem restrição de horário.
  horaInicio String?
  horaFim    String?
  // Dias da semana em que atende: índices separados por vírgula (0=domingo ... 6=sábado).
  diasSemana String                    @default("0,1,2,3,4,5,6")
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  instancias WhatsAppAgenteInstancia[]

  @@index([contaId, ativo])
}

// Vínculo agente <-> instância. O unique por instância garante que cada instância seja
// triada por no máximo um agente (o admin escolhe qual agente atende cada instância).
model WhatsAppAgenteInstancia {
  id          Int               @id @default(autoincrement())
  contaId     Int
  agenteId    Int
  instanciaId Int
  Agente      WhatsAppAgente    @relation(fields: [agenteId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Instancia   WhatsAppInstancia @relation(fields: [instanciaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt   DateTime          @default(now())

  @@unique([contaId, instanciaId])
  @@index([contaId, agenteId])
}

// Configuração global de IA da plataforma, gerenciada pelo CEO (super admin). Os assinantes
// NÃO informam a própria chave: usam a chave marcada como padrão aqui e apenas os modelos ativos.
model IaChaveApi {
  id        Int      @id @default(autoincrement())
  nome      String
  provider  String   @default("gemini")
  apiKey    String   @db.Text
  ativo     Boolean  @default(true)
  isPadrao  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, ativo, isPadrao])
}

model IaModelo {
  id        Int      @id @default(autoincrement())
  modelId   String   @unique
  nome      String
  provider  String   @default("gemini")
  ativo     Boolean  @default(true)
  // Custo por 1 milhão de tokens (na moeda do CEO). Usado para estimar o gasto a partir de IaUso.
  custoInputMilhao  Decimal? @db.Decimal(12, 6)
  custoOutputMilhao Decimal? @db.Decimal(12, 6)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Configuração (singleton) do chat "Core IA" — o assistente interno do ERP. Gerenciada pelo
// CEO/super admin: define o modelo, a chave de API dedicada, o prompt de sistema e o
// comportamento usados para atender os clientes do sistema.
model IaCoreConfig {
  id           Int      @id @default(autoincrement())
  provider     String   @default("gemini")
  modelId      String   @default("gemini-2.0-flash-lite")
  apiKey       String?  @db.Text
  systemPrompt String?  @db.LongText
  ativo        Boolean  @default(true)
  // Limite mensal padrão de tokens de IA por conta (null = ilimitado). O CEO define aqui o
  // teto global; cada conta pode ter um override em ParametrosConta.iaLimiteTokensMensal.
  limiteTokensMensalPadrao Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Consumo de tokens de IA por conta/feature (para medição e limite mensal). Uma linha por
// chamada ao modelo. Não referencia FK forte de Contas para não travar limpezas.
model IaUso {
  id               Int      @id @default(autoincrement())
  contaId          Int
  feature          String
  provider         String   @default("gemini")
  modelId          String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([contaId, createdAt])
}

model WhatsAppContato {
  id              Int                   @id @default(autoincrement())
  contaId         Int
  Conta           Contas                @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  telefone        String
  nome            String?
  // Marca que o nome foi definido manualmente pelo usuário; quando true, os webhooks (pushName)
  // não sobrescrevem mais o nome do contato.
  nomeManual      Boolean               @default(false)
  foto            String?               @db.Text
  clienteId       Int?
  Cliente         ClientesFornecedores? @relation(fields: [clienteId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  dadosAuxiliares String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  conversas       WhatsAppConversa[]

  @@unique([contaId, telefone])
  @@index([contaId, clienteId])
}

model WhatsAppConversa {
  id                Int                    @id @default(autoincrement())
  contaId           Int
  Conta             Contas                 @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  instanciaId       Int
  Instancia         WhatsAppInstancia      @relation(fields: [instanciaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  contatoId         Int
  Contato           WhatsAppContato        @relation(fields: [contatoId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clienteId         Int?
  Cliente           ClientesFornecedores?  @relation(fields: [clienteId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  telefone          String
  status            WhatsAppConversaStatus @default(ABERTA)
  atendenteId       Int?
  Atendente         Usuarios?              @relation("WhatsAppAtendente", fields: [atendenteId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  setor             String?
  fila              String?
  canal             String                 @default("whatsapp")
  ultimaMensagem    String?                @db.Text
  ultimaInteracaoEm DateTime?
  naoLidas          Int                    @default(0)
  // Estado do ciclo de atendimento atual: quando entrou na fila e quando foi assumida. São
  // sobrescritos a cada ciclo (a thread é reaproveitada); o histórico fica em
  // WhatsAppConversaEvento. Servem para a espera da fila agora e para datar o evento seguinte.
  filaDesde         DateTime?
  atendidaEm        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  mensagens         WhatsAppMensagem[]
  eventos           WhatsAppConversaEvento[]

  @@unique([contaId, instanciaId, telefone])
  @@index([contaId, status, ultimaInteracaoEm])
  @@index([contaId, atendenteId])
  @@index([contaId, clienteId])
  @@index([contaId, filaDesde])
}

// Log append-only das transições de atendimento. Cada linha é um fato imutável, então
// reabrir uma conversa não apaga o ciclo anterior (ao contrário de datas na conversa).
model WhatsAppConversaEvento {
  id         Int                        @id @default(autoincrement())
  contaId    Int
  Conta      Contas                     @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  conversaId Int
  Conversa   WhatsAppConversa           @relation(fields: [conversaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tipo       WhatsAppConversaEventoTipo
  usuarioId  Int?
  Usuario    Usuarios?                  @relation("WhatsAppConversaEventoAutor", fields: [usuarioId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // Início do intervalo que este evento fecha: entrada na fila (ASSUMIDA) ou início do
  // atendimento (FINALIZADA). Permite medir espera e duração sem parear linhas do log.
  referenciaEm DateTime?
  createdAt  DateTime                   @default(now())

  @@index([contaId, tipo, createdAt])
  @@index([contaId, conversaId, createdAt])
  @@index([contaId, usuarioId, tipo, createdAt])
}

model WhatsAppMensagem {
  id                Int                     @id @default(autoincrement())
  contaId           Int
  Conta             Contas                  @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  conversaId        Int
  Conversa          WhatsAppConversa        @relation(fields: [conversaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  instanciaId       Int
  Instancia         WhatsAppInstancia       @relation(fields: [instanciaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  direcao           WhatsAppMensagemDirecao
  tipo              WhatsAppMensagemTipo    @default(TEXTO)
  externalMessageId String
  conteudo          String?                 @db.Text
  mediaUrl          String?                 @db.Text
  mediaMimeType     String?
  fileName          String?
  rawPayload        String?                 @db.LongText
  statusEnvio       WhatsAppMensagemStatus  @default(PENDENTE)
  erroEnvio         String?                 @db.Text
  enviadoEm         DateTime?
  lidoEm            DateTime?
  // Preenchido quando o remetente apaga a mensagem (evento protocolMessage REVOKE da W-API):
  // mantemos a mensagem original e apenas marcamos como apagada para exibir a badge no chat.
  apagadaEm         DateTime?
  // Reações (evento reactionMessage da W-API): não criam balão próprio; ficam guardadas como
  // JSON na mensagem reagida (array de { emoji, fromMe, senderId }) para exibir abaixo do balão.
  reacoes           String?                 @db.Text
  // Resposta/citação (contextInfo.stanzaID da W-API): quando esta mensagem responde a outra,
  // guardamos o id externo da mensagem citada e um resumo do conteúdo dela para exibir o
  // trecho citado acima do balão (como no WhatsApp).
  quotedMessageId   String?
  quotedConteudo    String?                 @db.Text
  // Quem produziu a mensagem, e qual usuário a enviou quando `origem` é ATENDENTE.
  origem            WhatsAppMensagemOrigem?
  usuarioId         Int?
  Usuario           Usuarios?               @relation("WhatsAppMensagemAutor", fields: [usuarioId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([contaId, instanciaId, externalMessageId])
  @@index([contaId, conversaId, createdAt])
  @@index([contaId, statusEnvio])
  @@index([contaId, origem, createdAt])
  @@index([contaId, usuarioId, createdAt])
}

model WhatsAppWebhookEvento {
  id          Int               @id @default(autoincrement())
  contaId     Int
  Conta       Contas            @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  instanciaId Int
  Instancia   WhatsAppInstancia @relation(fields: [instanciaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  eventId     String
  tipo        String
  // Telefone do chat a que o evento pertence (msg.phone), quando é um evento de mensagem. Usado
  // para apagar os webhooks correspondentes ao excluir a conversa/contato. Nulo p/ eventos sem
  // telefone (connected/disconnected/status/presence).
  telefone    String?
  payload     String            @db.LongText
  processado  Boolean           @default(false)
  erro        String?           @db.Text
  createdAt   DateTime          @default(now())
  processedAt DateTime?

  @@unique([instanciaId, eventId])
  @@index([contaId, tipo, createdAt])
  @@index([instanciaId, telefone])
}
