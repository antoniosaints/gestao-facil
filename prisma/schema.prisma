model Produto {
  id                   Int                    @id @default(autoincrement())
  contaId              Int
  Contas               Contas                 @relation(fields: [contaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  produtoBaseId        Int?
  ProdutoBase          ProdutoBase?           @relation(fields: [produtoBaseId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  Uid                  String                 @default("PRO_000")
  status               Status                 @default(ATIVO)
  categoria            String?
  nome                 String
  nomeVariante         String                 @default("Padrão")
  ehPadrao             Boolean                @default(false)
  // Texto livre onde o usuário descreve a variante; `@db.Text` porque o VARCHAR(191) padrão
  // do MySQL não comporta uma descrição de verdade.
  descricao            String?                @db.Text
  preco                Decimal                @db.Decimal(10, 2)
  // Preço promocional (opcional). Quando definido e menor que `preco`, a variante entra na
  // seção "Promoções" da loja e é vendida por este valor. `null` = sem promoção.
  precoPromocional     Decimal?               @db.Decimal(10, 2)
  precoCompra          Decimal?               @db.Decimal(10, 2)
  entradas             Boolean?               @default(true)
  saidas               Boolean?               @default(true)
  unidade              String?
  estoque              Int
  minimo               Int
  codigo               String?
  ncm                  String?
  cest                 String?
  cfop                 String?
  origem               Int?
  aliquotaIcms         Decimal?               @db.Decimal(5, 2)
  aliquotaIpi          Decimal?               @db.Decimal(5, 2)
  aliquotaPis          Decimal?               @db.Decimal(5, 2)
  aliquotaCofins       Decimal?               @db.Decimal(5, 2)
  codigoProduto        String?
  issAliquota          Decimal?               @db.Decimal(5, 2)
  controlaEstoque      Boolean?               @default(false)
  producaoLocal        Boolean?               @default(false)
  mostrarNoPdv         Boolean?               @default(true)
  materiaPrima         Boolean?               @default(false)
  custoMedioProducao   Decimal?               @db.Decimal(10, 2)
  // Imagem da variante (uma por variante). Guarda a referência do storage (URL pública no R2 ou a
  // chave local), no mesmo padrão de `Contas.profile`. Ao excluir a variante a imagem é apagada.
  imagem               String?                @db.Text
  // Controla se a variante aparece no catálogo/loja online pública. Default: aparece.
  mostrarNoCatalogo    Boolean                @default(true)
  ItensVendas          ItensVendas[]
  MovimentacoesEstoque MovimentacoesEstoque[]
  ItensOrdensServico   ItensOrdensServico[]
  ComandaItens         ComandaItem[]
  assinaturaItens      AssinaturaItem[]
  planoAssinaturaItens PlanoAssinaturaItem[]
  assinaturaComodatos  AssinaturaComodato[]
  LojaPedidoItens      LojaPedidoItem[]
  LojaReservas         LojaReservaEstoque[]

  @@unique([id, contaId])
  @@index([produtoBaseId])
}

