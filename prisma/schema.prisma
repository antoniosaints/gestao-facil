enum WhatsAppMensagemDirecao {
  ENTRADA
  SAIDA
}

// Quem produziu a mensagem. `direcao` sozinha não distingue uma resposta do atendente de uma
// resposta automática do agente de IA (ambas são SAIDA), o que inviabiliza medir tempo de
// resposta humano e produtividade. Nulo = mensagem anterior à instrumentação (origem desconhecida).
enum WhatsAppMensagemOrigem {
  CONTATO // recebida do cliente
  ATENDENTE // enviada por um usuário pelo sistema
  AGENTE_IA // resposta automática do agente de IA
  DISPOSITIVO // enviada direto do aparelho/WhatsApp Web, fora do sistema
}

// Ciclo de atendimento de uma conversa. A conversa é uma thread rolante por contato
// (unique contaId+instanciaId+telefone) e seu status é sobrescrito a cada transição, então
// datas gravadas na própria conversa se perdem quando o cliente volta a falar. Este log é
// append-only e é a fonte de verdade para os KPIs por período.
enum WhatsAppConversaEventoTipo {
  ENFILEIRADA // entrou na fila aguardando atendimento humano
  ASSUMIDA // um atendente assumiu
  FINALIZADA // atendimento encerrado
}

enum WhatsAppMensagemTipo {
  TEXTO
  IMAGEM
  AUDIO
  VIDEO
  DOCUMENTO
  STICKER
  LINK
  LOCALIZACAO
  CONTATO
  OUTRO
}

enum WhatsAppMensagemStatus {
  PENDENTE
  ENVIADA
  ENTREGUE
  LIDA
  ERRO
  RECEBIDA
}

enum WhatsAppPagamentoMetodo {
  PIX
